header.header
  .container
    .row.align-items-center
      .col-2
        .inner-logo
          a(href="/")
            img(src=settingGeneral.logo, alt=settingGeneral.websiteName)


      .col-6
        .box-search
          form(action="/search/result" method="GET")
            div(class="form-group d-flex mb-0")
              input(
                type="text"
                placeholder="Nhập từ khóa..."
                class="form-control"
                name="keyword"
                value=keyword
              )
              button(type="submit" class="btn btn-primary") Tìm

          .inner-suggest
            .inner-list
              a(href="/songs/detail/:slugSong" class="inner-item")
                .inner-image
                  img(src="https://backend.daca.vn/assets/images/cat-doi-noi-sau.jpg")
                .inner-info
                  .inner-title Cắt đôi nỗi sầu
                  .inner-singer
                    i(class="fa-solid fa-microphone-lines")
                    | Tăng Duy Tân
              
        
      .col-4
        .inner-menu
          ul
            li
              a(href="/") Trang chủ
            li
              a(href="/topics") Chủ đề
            li
              a(href="/favorite-songs") Yêu thích
            if(user)
              li
                a(href="/users/logout") Đăng xuất
            else
              li
                a(href="/users/login") Đăng nhập
              li
                a(href="/users/register") Đăng ký