extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-5
    //- 1. Phân loại theo thể loại (Topic/Category)
    .section-topics.mb-5
      +box-head("Thể loại âm nhạc")
      .row
        each topic in topics
          .col-6.col-md-3.col-lg-2.mb-3
            a(href=`/songs/${topic.slug}` class="text-decoration-none")
              .card.inner-topic-card.text-center.border-0.shadow-sm
               
                .card-body.p-2
                  h6.card-title.text-dark #{topic.title}

    //- 2. Nghệ sĩ phổ biến (Popular Singers)
    .section-singers.mb-5
      +box-head("Nghệ sĩ phổ biến")
      .row
        each singer in singers
          .col-6.col-md-4.col-lg-2.mb-4
            .inner-singer-item.text-center( style="flex-direction: column;display: flex; align-items: center;")

              a(href=`/singers/${singer.slug}`)
                .inner-avatar.mb-2
                  img(src=singer.avatar, alt=singer.fullName, class="rounded-circle shadow-sm" style="width: 120px; height: 120px; object-fit: cover;")
              a(href=`/singers/${singer.slug}` class="text-decoration-none")
                h6.inner-name.text-dark.mt-2 #{singer.fullName}

    //- 3. Bài hát theo nghệ sĩ / Bài hát mới (Songs)
    .section-songs.mb-5
      +box-head("Bài hát nổi bật")
      .row
        each song in songs
          .col-12.col-md-6.col-lg-4.mb-3
            .song-item.p-2.border.rounded.shadow-sm.bg-white
              .d-flex.align-items-center
                .inner-image.mr-3(style="width: 80px; height: 80px;")
                  a(href=`/songs/detail/${song.slug}`)
                    img(src=song.avatar, alt=song.title, class="rounded w-100 h-100" style="object-fit: cover;")
                .inner-info.flex-grow-1
                  h6.inner-title.mb-1
                    a(href=`/songs/detail/${song.slug}` class="text-dark font-weight-bold") #{song.title}
                  p.inner-singer.small.text-muted.mb-1
                    i.fa-solid.fa-microphone-lines.mr-1
                    | #{song.infoSinger ? song.infoSinger.fullName : 'Đang cập nhật'}
                  .inner-meta.d-flex.justify-content-between.align-items-center
                    span.small.text-primary
                      i.fa-solid.fa-headphones.mr-1
                      | #{song.listen || 0}
                    span.small.text-danger
                      i.fa-solid.fa-thumbs-up.mr-1
                      | #{song.like ? song.like.length : 0}