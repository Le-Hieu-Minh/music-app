extends ../../layouts/auth.pug

block main
  .container.my-5
    .row.justify-content-center
      .col-8
        h1(class="text-center") Quên mật khẩu
        form(
          action="/users/fogot-password"
          method="POST"
        )     
          div(class="form-group")
            label(for="email") Email
            input(
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
            )
            
          div(class="form-group")
            button(
                type="submit"
                class="btn btn-primary btn-block"
            ) Xác nhận