extends ../../layouts/auth.pug

block main
  .container.my-5
    .row.justify-content-center
      .col-8
        h1(class="text-center") Đăng ký tài khoản
        form(
          action="/users/fogot-password/reset-password"
          method="POST"
        )     
          div(class="form-group")
            label(for="password") Mật khẩu mới
            input(
                type="password"
                class="form-control"
                id="password"
                name="password"
                required
            )
            
          div(class="form-group")
            label(for="confirmPassword") Nhập lại mật khẩu
            input(
                type="password"
                class="form-control"
                id="confirmPassword"
                name="confirmPassword"
                required
            )
              
          div(class="form-group")
            button(
                type="submit"
                class="btn btn-primary btn-block"
            ) Xác nhận
        