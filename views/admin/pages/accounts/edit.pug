extends ../../layouts/default.pug


block main
  if(role.permissions.includes('accounts_edit'))
    h1(class="mb-4") Thêm mới tài khoản

    form(
      action=`/${prefixAdmin}/accounts/edit/${account.id}?_method=PATCH`
      method="POST"
      
    )
      div(class="form-group")
        label(for="fullName") Họ tên *
        input(
          type="text"
          class="form-control"
          id="fullName"
          name="fullName"
          value=account.fullName
          required
        )
      div(class="form-group")
        label(for="email") Email *
        input(
          type="email"
          class="form-control"
          id="email"
          name="email"
          value=account.email
          required
        )

      div(class="form-group")
        label(for="password") Mật khẩu *
        input(
          type="password"
          class="form-control"
          id="password"
          name="password"
          required
        )

      div(class="form-group")
        label(for="phone") Số điện thoại
        input(
          type="text"
          class="form-control"
          id="phone"
          name="phone"
          value=account.phone
        )

      
      div(class="form-group")
        label(for="role_id") Phân quyền
        select(name="role_id" id="role_id" class="form-control")
          option(disabled) -- Chọn --
          each role in roles
            option(
              value=role.id 
              selected=(role.id==account.role_id?true:false) 
              ) #{role.title}
        

      div(class="form-group form-check form-check-inline")
        input(
          type="radio"
          class="form-check-input"
          id="statusActive"
          name="status"
          value="active"
          checked=(account.status=="active"?true:false)
        )
        label(for="statusActive" class="form-check-label") Hoạt động

      div(class="form-group form-check form-check-inline")
        input(
          type="radio"
          class="form-check-input"
          id="statusInactive"
          name="status"
          value="inactive"
          checked=(account.status=="inactive"?true:false)
        )
        label(for="statusActive" class="form-check-label") Dừng hoạt động

      div(class="form-group")
        button(type="submit" class="btn btn-primary") Tạo mới
  else 
    h1 bạn ko có quyền sửa tài khoản mới



