extends ../../layouts/auth.pug


block main
  .container

    .row.justify-content-center
      .col-md-8
        form(action=`/${prefixAdmin}/auth/login` method="POST" )
          h1.mb-4.text-center Đăng nhập
          .form-group
            label(for="email") Email
            input#email.form-control(type="email" name="email" required)

          div(class="form-group")
            label(for="password") Mật khẩu
            input(
              type="password"
              class="form-control"
              id="password"
              name="password"
              required
            )

          div(class="form-group")
            button(
              type="submit"
              class="btn btn-primary btn-block"
            ) Đăng nhập

