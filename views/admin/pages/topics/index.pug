extends ../../layouts/default.pug

block main
  if(role.permissions.includes('music-category_view'))
    h1(class="mb-4") #{pageTitle}
    .card.mb-3
        .card-header Danh sách
        .card-body
            .row
                .col-8
                .col-4.text-right
                  if(role.permissions.includes('music-category_create'))
                    a(href=`/${prefixAdmin}/topics/create` class="btn btn-outline-success") + Thêm mới
            
            table(class="table table-hover table-sm")
              thead
                tr
                  th STT
                  th Hình ảnh
                  th Tiêu đề
                  th Trạng thái
                  th Hành động
              tbody
                each item, index in topics
                  tr
                    td #{index+1}
                    td
                      img(
                        src=item.avatar
                        alt=item.title
                        width="100px"
                        height="auto"
                      )
                    td #{item.title}
                    td
                      if (item.status === "active")
                        a(
                          href="javascript:;"
                          class="badge badge-success"
                          button-status
                          data-status=item.status
                          data-id=item.id
                        ) Hoạt động
                      else
                        a(
                          href="javascript:;"
                          class="badge badge-danger"
                          button-status
                          data-status=item.status
                          data-id=item.id
                        ) Dừng hoạt động
                    td
                      if(role.permissions.includes('music-category_view'))
                        a(
                          class="btn btn-secondary btn-sm"
                          href=`/${prefixAdmin}/topics/detail/${item.id}`
                        ) Chi tiết
                      if(role.permissions.includes('music-category_edit'))
                        a(
                          class="btn btn-warning btn-sm ml-1"
                          href=`/${prefixAdmin}/topics/edit/${item.id}`
                        ) Sửa
                      if(role.permissions.includes('music-category_delete'))
                        button(
                          class="btn btn-danger btn-sm ml-1"
                          button-delete
                          data-id=item.id
                        ) Xóa
  else
    h1 Bạn ko có quyền xem danh sách chủ đề