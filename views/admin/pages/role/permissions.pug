extends ../../layouts/default.pug

block main
  if(role.permissions.includes('roles_premissions'))
    h1(class="mb-4") Phan quyen
    if(record)
      //- Thêm thuộc tính data-records để JS có thể lấy dữ liệu gốc nếu cần
      div(data-records=record)
        div(class="text-right")
          button(
              type="button" 
              class="btn btn-primary mb-3"
              button-submit
          ) Cập nhật

        table(class="table table-hover table-sm" table-premissions)
          thead
              tr
                th Tính năng
                each item in record
                    th(class="text-center") #{item.title}
          tbody
              //- id của role (dùng để định danh khi gửi data)
              tr.d-none(data-name="id")
                td
                each item in record
                    td(class="text-center")
                      input(type="text" value=item.id)
              
              //- Danh mục chủ đề
              tr
                td(colspan=record.length + 1)
                    b Danh mục chủ đề
              
              tr(data-name="music-category_view")
                td Xem
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="music-category_create")
                td Thêm mới
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="music-category_edit")
                td Chỉnh sửa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="music-category_delete")
                td Xóa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")
              //- Danh mục bài hát
              tr
                td(colspan=record.length + 1)
                    b Danh mục bài hát
              
              tr(data-name="music_view")
                td Xem
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="music_create")
                td Thêm mới
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="music_edit")
                td Chỉnh sửa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="music_delete")
                td Xóa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")
              //- Danh mục ca sỹ
              tr
                td(colspan=record.length + 1)
                    b Danh mục ca sỹ
              
              tr(data-name="singer_view")
                td Xem
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="singer_create")
                td Thêm mới
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="singer_edit")
                td Chỉnh sửa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="singer_delete")
                td Xóa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")
              //- Danh mục nhóm quyền
              tr
                td(colspan=record.length + 1)
                    b Danh mục nhóm quyền
              
              tr(data-name="roles_view")
                td Xem
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="roles_create")
                td Thêm mới
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="roles_edit")
                td Chỉnh sửa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="roles_delete")
                td Xóa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              //- Danh mục accounts
              tr
                td(colspan=record.length + 1)
                    b Danh mục Tài khoản admin
              
              tr(data-name="accounts_view")
                td Xem
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="accounts_create")
                td Thêm mới
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="accounts_edit")
                td Chỉnh sửa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr(data-name="accounts_delete")
                td Xóa
                each item in record
                    td(class="text-center")
                      input(type="checkbox")

              tr
                td(colspan=record.length + 1)
                    b Danh mục phân quyền
                      
              tr(data-name="roles_premissions")
               td Phân quyền
               each item in record
                  td(class="text-center")
                     input(type="checkbox")
  else 
    h1 bạn ko có quyền phân quyền

block script
  script(src="/admin/js/roles.js")